{
  "realm": "datawave",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "keycloak",
  "clients": [
    {
      "clientId": "trino-sso",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "trino-sso-secret",
      "redirectUris": [
        "http://localhost:4180/oauth2/callback"
      ],
      "webOrigins": [
        "http://localhost:4180"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "trino-sso",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "aud"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "datawave-admin",
      "enabled": true,
      "email": "admin@datawave.local",
      "firstName": "DataWave",
      "lastName": "Admin",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ]
    },
    {
      "username": "datawave-analyst",
      "enabled": true,
      "email": "analyst@datawave.local",
      "firstName": "DataWave",
      "lastName": "Analyst",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "analyst123",
          "temporary": false
        }
      ]
    }
  ]
}
